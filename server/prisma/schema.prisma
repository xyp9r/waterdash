// Это настройки того, как Prisma будет генерировать нам автокомплит
generator client {
  provider = "prisma-client-js"
}

// Это указание, куда стучаться ( в наш PostgreSQL в докере)
datasource db {
  provider = "postgresql"
  url         = env("DATABASE_URL")
}

// Таблица юзеров

model User {
  id               String          @id @default(uuid())
  email          String          @unique // Почта должна быть уникальной, нельзя создать 2 акка на одну почту
  password    String          // Тут будет храниться зашифрованый пароль (хеш)
  dailyGoal     Int              @default(2000) // Цель воды, по стандарту 2л
  name          String?        // Имя пользователя (необязательно)
  logs            WaterLog[]  // Связь: у одного юзера может быть много записей о воде
  createdAt    DateTime     @default(now())
}

// Таблица выпитых напитков

model WaterLog {
  id                String       @id @default(uuid()) // Уникальный ID (uuid генерирует сложные строки типа "123e4567-e89b-...")
  amount        Int            // Количество миллилитров (Int = целое число)
  name           String       // Название напитка
  icon             String       // Иконка
  createdAt DateTime @default(now()) // Сервер сам запишет точное время когда стакан был добавлен

  // Добавляем связь с юзером

  userId           String        // ID владельца стакана
  user             User          @relation(fields: [userId], references: [id])
}